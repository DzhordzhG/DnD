<UserControl x:Class="DnDCombater.Views.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DnDCombater.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
		<Viewbox Stretch="Fill">
			<Grid Height="1080" Width="1920">
				<Grid.Background>
					<ImageBrush ImageSource="/Resources/Backgrounds/filth.jpg"
                    Stretch="Fill"/>
				</Grid.Background>
				<Grid Grid.Row="0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="30*" />
						<ColumnDefinition Width="60*" />
						<ColumnDefinition Width="30*" />
					</Grid.ColumnDefinitions>

					<!-- Rows -->
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
						<RowDefinition Height="1*"/>
						<RowDefinition Height="2*"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="2*"/>
					</Grid.RowDefinitions>
					<TextBlock Text="D&amp;D Combater"
                   FontSize="100"
				   FontFamily="Georgia"
				   Grid.Row="2"
				   Grid.Column="1"
				   Foreground="GreenYellow"
				   FontWeight="Heavy"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

					<Button 
					Content="Create Character"
					FontSize="30"
                    Command="{Binding OpenCharacterCreatorCommand}"
					Width="300"
					Height="50"
					FontWeight="Normal"
					Grid.Row="5"
					Grid.Column="1"/>
					<Button Content="Show Characters"
					FontSize="30"
                    Command="{Binding ShowCharactersCommand}"
					FontWeight="Normal"
					Width="300"
					Height="50"
					Grid.Row="4"
					Grid.Column="1"/>
					<Button Content="Start Combat"
					FontSize="40"
					FontWeight="SemiBold"
                    Command="{Binding StartCombatCommand}"
					Width="400"
					Height="70"
					Grid.Row="3"
					Grid.Column="1"/>
				</Grid>
			</Grid>
		</Viewbox>
	</Grid>
</UserControl>
