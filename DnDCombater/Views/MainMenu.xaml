<UserControl x:Class="DnDCombater.Views.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DnDCombater.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
	<Grid>
		<Viewbox Stretch="Fill">
			<Grid Height="1080" Width="1920">

				<Grid.Resources>
					<ImageBrush x:Key="AddButtonImageBrush" ImageSource="/resources/misc/sword.png" Stretch="UniformToFill"/>
				</Grid.Resources>

				<Grid Grid.Row="0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="30*" />
						<ColumnDefinition Width="60*" />
						<ColumnDefinition Width="30*" />
					</Grid.ColumnDefinitions>

					<!-- Rows -->
					<Grid.RowDefinitions>
						<RowDefinition Height="2*"/>
						<RowDefinition Height="2*"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<!-- Start Combat Button -->
					<Button Content="Start Combat"
							FontSize="40"
							FontWeight="SemiBold"
							VerticalAlignment="Bottom"
							Command="{Binding StartCombatCommand}"
							Width="400"
							Height="70"
							Grid.Row="2"
							Grid.Column="1">
					</Button>

					<!-- DnD Combater -->
					<TextBlock Text="D&amp;D Combater"
								FontSize="130"
								Grid.Row="1"
								Grid.Column="0"
								Foreground="CornflowerBlue"
								FontWeight="Heavy"
								FontFamily="/Resources/Fonts/#MedievalSharp"
							   Grid.ColumnSpan="3"
								HorizontalAlignment="Center"
						   VerticalAlignment="Center"/>

					<!-- Create Character Button -->
					<Button Content="Create Character"
							FontSize="30"
							Command="{Binding OpenCharacterCreatorCommand}"
							Width="320"
							Height="50"
							VerticalAlignment="Bottom"
							FontWeight="Bold"
							Grid.Row="3"
							Grid.Column="1"/>

					<!-- Show Characters Button -->
					<Button Content="Edit Characters"
							FontSize="30"
							Command="{Binding ShowCharactersCommand}"
							FontWeight="Bold"
							Width="320"
							Height="50"
							VerticalAlignment="Bottom"
							Grid.Row="4"
							Grid.Column="1"/>

					<!-- Add Battlemap Button -->
					<Button Content="Add Battlemap"
							FontSize="30"
							Command="{Binding BattlemapCreatorCommand}"
							Width="320"
							VerticalAlignment="Bottom"
							Height="50"
							FontWeight="Bold"
							Grid.Row="5"
							Grid.Column="1"/>
					<!-- Edit Battlemap Button -->
					<Button Content="Edit Battlemap"
							FontSize="30"
							Command="{Binding BattlemapEditorCommand}"
							Width="320"
							VerticalAlignment="Bottom"
							Height="50"
							FontWeight="Bold"
							Grid.Row="6"
							Grid.Column="1"/>

					<!-- Decorative Swords -->
					<Image Source="/resources/misc/sword.png" Height="149" Margin="-260,500,0,0" VerticalAlignment="Top" Grid.Column="2" Grid.RowSpan="3">
						<Image.RenderTransform>
							<RotateTransform Angle="270" />
						</Image.RenderTransform>
					</Image>
					<Image Source="/Resources/Misc/sword.png" Height="149" Margin="-620,230,0,0" VerticalAlignment="Top" Grid.Column="1" Grid.RowSpan="3">
						<Image.RenderTransform>
							<RotateTransform Angle="90" />
						</Image.RenderTransform>
					</Image>
				</Grid>
			</Grid>
		</Viewbox>
	</Grid>
</UserControl>
