<Window x:Class="DnDCombater.Views.CharacterListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DnDCombater.Views"
        mc:Ignorable="d"
        Title="Characters"
		WindowStartupLocation="CenterScreen"
		Icon="/Resources/D20.ico"
		Background="Black"
		Height="450" 
		Width="800">
	<Window.Resources>
		<Style TargetType="ListView">
			<Setter Property="FontFamily" Value="Georgia"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Background" Value="Black"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
		</Style>
		<Style TargetType="GridViewColumnHeader">
			<Setter Property="Background" Value="DarkOrange"/>
			<Setter Property="Foreground" Value="Black"/>
			<Setter Property="FontFamily" Value="Georgia"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="BorderBrush" Value="Orange"/>
			<Setter Property="BorderThickness" Value="0,0,1,1"/>
			<Setter Property="Padding" Value="5"/>
		</Style>

	</Window.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>
		<Grid Grid.Row="0">
			<ListView ItemsSource="{Binding Characters}"
					  SelectedItem="{Binding SelectedCharacter}">
				<ListView.View>
					<GridView>
						<GridViewColumn Header="Name"
								Width="230"
								DisplayMemberBinding="{Binding Name}" />

						<GridViewColumn Header="Class" 
								Width="160"
								DisplayMemberBinding="{Binding CharacterClass}" />

						<GridViewColumn Header="Subclass" 
								Width="160"
								DisplayMemberBinding="{Binding Subclass}" />

						<GridViewColumn Header="HP" 
								Width="50"
								DisplayMemberBinding="{Binding HP}" />

						<GridViewColumn Header="AC" 	
								Width="50"
								DisplayMemberBinding="{Binding AC}" />

						<GridViewColumn Header="Initiative" 
								Width="90"
								DisplayMemberBinding="{Binding Initiative}" />

						<GridViewColumn Header="Speed" 
								Width="60"
								DisplayMemberBinding="{Binding Speed}" />

					</GridView>
				</ListView.View>
			</ListView>			
		</Grid>
		<Grid Grid.Row="1">
			<Image Source="{Binding SelectedCharacterImage}"
			   Width="350"
			   Height="350"
			   Stretch="UniformToFill"/>
		</Grid>
	</Grid>
</Window>
