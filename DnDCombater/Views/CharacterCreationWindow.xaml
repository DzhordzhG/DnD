<Window x:Class="DnDCombater.Views.CharacterCreationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DnDCombater.Views"
        mc:Ignorable="d"
		WindowStartupLocation="CenterScreen"
		Icon="pack://application:,,,/Resources/D20.ico"
		ResizeMode="CanMinimize"
	Title="Create Character" Height="450" Width="800">
	<Window.Resources>
		<Style TargetType="TextBlock">
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="TextAlignment" Value="Center"/>
			<Setter Property="FontFamily" Value="Georgia"/>
			<Setter Property="HorizontalAlignment" Value="Center"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style TargetType="Button">
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="Foreground" Value="Black"/>
			<Setter Property="FontFamily" Value="Georgia"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
		</Style>
		<Style TargetType="TextBox">
			<Setter Property="FontWeight" Value="DemiBold"/>
			<Setter Property="Foreground" Value="Black"/>
			<Setter Property="Background" Value="White"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
			<Setter Property="FontFamily" Value="Georgia"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
		</Style>
	</Window.Resources>
	<Grid Background="Black" Margin="10">
		<!-- FORM -->
		<Grid Grid.Row="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="20*" />
				<ColumnDefinition Width="60*" />
				<ColumnDefinition Width="70*" />
			</Grid.ColumnDefinitions>

			<!-- Rows -->
			<Grid.RowDefinitions>
				<RowDefinition Height="*"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="40"/>
			</Grid.RowDefinitions>

			<!-- Image -->
			<Image Source="{Binding Image}"
			   Grid.Row="0"
			   Margin="20"
			   Grid.Column="2"
			   Grid.RowSpan="7"
			   Stretch="UniformToFill"/>

			<!-- Name -->
			<TextBlock Text="Name:" Grid.Column="0" Height="13"/>
			<TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" Height="15"/>

			<!-- Class -->
			<TextBlock Text="Class:" Grid.Row="1" Grid.Column="0" Height="15"/>
			<TextBox Text="{Binding CharacterClass, UpdateSourceTrigger=PropertyChanged}"
                 Grid.Row="1" Grid.Column="1" Height="15"/>

			<!-- Subclass -->
			<TextBlock Text="Subclass:" Grid.Row="2" Grid.Column="0" Height="15"/>
			<TextBox Text="{Binding Subclass, UpdateSourceTrigger=PropertyChanged}"
                 Grid.Row="2" Grid.Column="1" Height="15"/>

			<!-- HP -->
			<TextBlock Text="HP:" Grid.Row="3" Grid.Column="0" Height="15"/>
			<TextBox Text="{Binding HP, UpdateSourceTrigger=PropertyChanged}"
                 Grid.Row="3" Grid.Column="1" Height="15"/>

			<!-- AC -->
			<TextBlock Text="AC:" Grid.Row="4" Grid.Column="0" Height="15"/>
			<TextBox Text="{Binding AC, UpdateSourceTrigger=PropertyChanged}"
                 Grid.Row="4" Grid.Column="1" Height="15"/>

			<!-- Initiative -->
			<TextBlock Text="Initiative:" Grid.Row="5" Grid.Column="0" Height="15"/>
			<TextBox Text="{Binding Initiative, UpdateSourceTrigger=PropertyChanged}"
                 Grid.Row="5" Grid.Column="1" Height="15"/>

			<!-- Speed -->
			<TextBlock Text="Speed:" Grid.Row="6" Grid.Column="0" Height="15"/>
			<TextBox Text="{Binding Speed, UpdateSourceTrigger=PropertyChanged}"
                 Grid.Row="6" Grid.Column="1" Height="15"/>

			<!-- Button -->
			<Button Content="Save"
                Command="{Binding SaveCommand}"
                Background="DarkOrange"
                Grid.Row="7"
				Grid.Column="1"
                Grid.ColumnSpan="2" Grid.RowSpan="2"/>
			<Button Content="Upload Image"
                Command="{Binding UploadImageCommand}"
                Background="DarkOrange"
				Grid.Column="0"
                Grid.Row="7"
                Grid.ColumnSpan="1" Grid.RowSpan="2"/>
		</Grid>
	</Grid>
</Window>
