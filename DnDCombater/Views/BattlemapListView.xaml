<UserControl x:Class="DnDCombater.Views.BattlemapListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DnDCombater.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
	<UserControl.Resources>
		<Style TargetType="ListView">
			<Setter Property="FontFamily" Value="/Resources/Fonts/#Cinzel"/>
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="Foreground" Value="CornflowerBlue"/>
			<Setter Property="FontSize" Value="30"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="BorderBrush" Value="Black"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
		</Style>

		<Style TargetType="GridViewColumnHeader">
			<Setter Property="Background" Value="LightSlateGray"/>
			<Setter Property="Foreground" Value="Black"/>
			<Setter Property="IsHitTestVisible" Value="False"/>
			<Setter Property="FontFamily" Value="/Resources/Fonts/#Cinzel"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="FontSize" Value="30"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="Padding" Value="5"/>

			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="GridViewColumnHeader">

						<Border Background="{TemplateBinding Background}"
							BorderBrush="LightSlateGray"
							BorderThickness="0,0,1,1">

							<ContentPresenter
								HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
								VerticalAlignment="Center"
								Margin="{TemplateBinding Padding}" />

						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>
	<Viewbox Stretch="Fill">
		<Grid Height="1080" Width="1920" Background="Black">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>
			<Grid Grid.Column="0">
				<ListView ItemsSource="{Binding Battlemaps}"
					  SelectedItem="{Binding SelectedMap}" Margin="0,0,0,10">
					<ListView.View>
						<GridView>
							<GridViewColumn Header="Name"
								DisplayMemberBinding="{Binding Name}" />

							<GridViewColumn Header="Size" 
								DisplayMemberBinding="{Binding Size}" />
							
							<GridViewColumn Header="Created At" 
								DisplayMemberBinding="{Binding CreatedAt}" />

						</GridView>
					</ListView.View>
				</ListView>
			</Grid>
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition/>
					<RowDefinition Height="23*"/>
					<RowDefinition Height="1*"/>
				</Grid.RowDefinitions>
				
				<Grid Grid.Row="0">
					<GridViewColumnHeader
						FontSize="30"
						Content="Battlemap"/>
				</Grid>
				
				<Grid Grid.Row="1" Margin="100">
					<Image Source="{Binding SelectedMapImage}"
					   HorizontalAlignment="Center"
					   Margin="10, 0"
					   VerticalAlignment="Center"
					   Stretch="Fill"/>
				</Grid>
				
				<Grid Grid.Row="2">
					<Button

						HorizontalAlignment="Stretch"
						VerticalAlignment="Stretch"
						Content="Delete Map"
						FontSize="30"
						Command="{Binding DeleteMapCommand}" Margin="-7,0,0,0"/>
				</Grid>
			</Grid>
		</Grid>
	</Viewbox>
</UserControl>
