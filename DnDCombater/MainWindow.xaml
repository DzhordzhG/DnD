<Window x:Class="DnDCombater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DnDCombater"
        mc:Ignorable="d"
		WindowStartupLocation="CenterScreen"
		Icon="pack://application:,,,/Resources/D20.ico"
        Title="DnD Combater" Height="450" Width="800">
    <Grid>
        <TextBlock Text="{Binding Title}"
                   FontSize="24"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

		<Button Content="Create Character"
                    Command="{Binding OpenCharacterCreatorCommand}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
				    Foreground="Green"
				    Background="Transparent"
                    Margin="100"/>

	</Grid>
</Window>
